# AI provider: Groq is primary; Ollama remains available as fallback.
AI_PROVIDER=groq
AI_FALLBACK_PROVIDER=ollama

# Groq
GROQ_MODEL=openai/gpt-oss-20b
GROQ_API_KEY=

# Ollama fallback
OLLAMA_MODEL=gpt-oss:20b

# PostgreSQL (empty host = Unix socket for peer auth)
DB_HOST=
DB_NAME=postgres
DB_USER=grau
DB_PASSWORD=
DB_PORT=5432
